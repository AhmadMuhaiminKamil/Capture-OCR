{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 60,
      "includeFiles": "node_modules/tesseract.js-core/**,node_modules/canvas/**"
    }
  },
  "routes": [
    {
      "src": "/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/",
      "dest": "/api/webhook.js"
    }
  ]
}