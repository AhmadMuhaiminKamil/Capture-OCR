{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/webhook.js": {
      "maxDuration": 60,
      "includeFiles": "api/tesseract.js-core/**,api/tesseract-src/**,api/lang-data/**,api/node_modules/**"
    }
  },
  "routes": [
    { "src": "/webhook", "dest": "/api/webhook.js" },
    { "src": "/", "dest": "/api/webhook.js" }
  ]
}